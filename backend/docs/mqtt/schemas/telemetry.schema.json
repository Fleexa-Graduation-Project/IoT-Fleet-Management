{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Telemetry Schema",
  "description": "The standard wrapper for all upstream IoT messages",
  "type": "object",
  "required": [
    "user_id",
    "device_id",
    "timestamp",
    "type",
    "payload"
  ],

  "properties": {
    "user_id": {
      "type": "string",
      "minLength": 3,
      "description": "Cognito sub of the device owner"
    },
    "device_id": {
      "type": "string",
      "minLength": 3,
      "description": "Unique ID like gas-sensor-01"
    },

    "timestamp": {
      "type": "integer",
      "minimum": 0,
      "description": "Unix timestamp in seconds"
    },

    "type": {
      "type": "string",
      "description": "device type (e.g. temp-sensor, ac-actuator)"
    },

    "payload": {
      "type": "object",
      "minProperties": 1,
      "description": "The actual sensor data"
    }
  },

  "additionalProperties": false
}